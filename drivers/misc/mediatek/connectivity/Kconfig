config MTK_COMBO
	tristate "MediaTek Connectivity Combo Chip Support"
	select BT
	help
	  MTK connectivity combo chip driver for MT66xx
	  This config is used to turn on/off connsys

choice
	prompt "Select Chip"
	depends on MTK_COMBO
	help
	  This is used to select chip.
	  When MTK_COMBO is y, we need to choose a chip.

